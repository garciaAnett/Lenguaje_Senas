# ──────────────────────────────────────────────
# Variables de entorno – Backend Sign Language MVP
# Copia este archivo como .env y rellena los valores
# ──────────────────────────────────────────────

# Puerto del servidor (default: 8000)
PORT=8000

# ── Hugging Face (Sprint 3) ─────────────────────
# Token de acceso a Hugging Face Hub
HUGGINGFACE_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID del modelo fine-tuned en Hugging Face Hub
# Formato: <usuario>/<nombre-repo>
HF_MODEL_ID=villarroel/videomae-sign-language-mvp

# ── Modo de operación ───────────────────────────
# "mock"  → Sprint 1/2: predicción simulada (no carga modelo)
# "real"  → Sprint 3/4: inferencia real con VideoMAE
APP_MODE=mock

# ── Checkpoint local (Sprint 3) ─────────────────
# Ruta al modelo entrenado (relativa a backend/ o absoluta)
# Descomentar después de ejecutar: python scripts/train_videomae.py
# LOCAL_MODEL_PATH=models/checkpoints/videomae-sign-language/best
